---
const { build } = Astro.props;
const info = build.info;
const words = info.title.toUpperCase().split(" ");
const title = words.length > 1 ? words.slice(0, -1).join(" ") : "";
const titleLastWord = words.at(-1)!;
---

<header class="hero" role="banner">
  <div class="hero__grid" aria-hidden="true"></div>
  <p class="hero__eyebrow">◈ Dark Souls III ◈ Build Guide ◈</p>
  <h1 class="hero__title">
    {
      title && (
        <>
          {title}
          <br />
        </>
      )
    }
    <em>{titleLastWord}</em>
  </h1>
  <p class="hero__tags">{info.tags.en}</p>
  <div class="hero__rule" aria-hidden="true"></div>
  <p class="hero__description">{info.description.en}</p>
  <div class="hero__badge" aria-label="Build summary">
    <div class="hero__badge-item">
      <span class="hero__badge-label">Starting Class</span>
      <span class="hero__badge-value">{info.startingClass}</span>
    </div>
    <div class="hero__badge-separator" aria-hidden="true"></div>
    <div class="hero__badge-item">
      <span class="hero__badge-label">Soul Level</span>
      <span class="hero__badge-value">{info.targetLevel}</span>
    </div>
  </div>
  <p class="hero__scroll-hint" aria-hidden="true">↓ SCROLL DOWN ↓</p>
</header>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px 130px;
    overflow: hidden;
    background: radial-gradient(
      ellipse at 50% 55%,
      var(--radial-glow) 0%,
      transparent 68%
    );
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 59px,
        var(--accent) 09 60px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 59px,
        var(--accent) 09 60px
      );
  }

  .hero__eyebrow {
    font-family: "Cinzel", serif;
    font-size: 12px;
    letter-spacing: 8px;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 18px;
    animation: fadeUp 0.9s ease both 0.3s;
  }

  .hero__title {
    font-family: "Cinzel Decorative", cursive;
    font-size: clamp(32px, 8vw, 82px);
    font-weight: 900;
    line-height: 1.06;
    color: var(--text);
    text-shadow:
      0 0 40px var(--glow),
      0 0 90px var(--glow),
      2px 3px 0 rgba(0, 0, 0, 0.8);
    animation: fadeUp 0.9s ease both 0.55s;
  }

  .hero__title em {
    font-style: normal;
    color: var(--accent-glow);
    text-shadow:
      0 0 18px var(--glow),
      0 0 50px var(--glow);
  }

  .hero__tags {
    font-family: "Cinzel", serif;
    font-size: 12px;
    letter-spacing: 5px;
    color: var(--gold);
    text-transform: uppercase;
    margin-top: 22px;
    animation: fadeUp 0.9s ease both 0.75s;
  }

  .hero__rule {
    width: 280px;
    height: 1px;
    margin: 28px auto;
    background: linear-gradient(
      to right,
      transparent,
      var(--accent),
      var(--gold),
      var(--accent),
      transparent
    );
    animation: fadeUp 0.9s ease both 0.9s;
  }

  .hero__description {
    max-width: 640px;
    color: var(--text-dim);
    font-style: italic;
    font-size: 18px;
    animation: fadeUp 0.9s ease both 1.05s;
  }

  .hero__badge {
    display: inline-flex;
    gap: 28px;
    align-items: center;
    margin-top: 36px;
    padding: 16px 36px;
    border: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.35);
    animation: fadeUp 0.9s ease both 1.2s;
  }

  .hero__badge-item {
    text-align: center;
  }

  .hero__badge-label {
    display: block;
    font-family: "Cinzel", serif;
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold-dim);
    margin-bottom: 4px;
  }

  .hero__badge-value {
    font-family: "Cinzel Decorative", cursive;
    font-size: 28px;
    font-weight: 900;
    color: var(--gold);
    text-shadow: 0 0 20px rgba(201, 168, 76, 0.4);
  }

  .hero__badge-separator {
    width: 1px;
    height: 42px;
    background: var(--border);
  }

  .hero__scroll-hint {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    font-family: "Cinzel", serif;
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--gold-dim);
    animation: pulse 2.5s ease-in-out infinite 2s;
  }
</style>
