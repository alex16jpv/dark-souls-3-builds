---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import data from "../data/builds.json";
import Sections from "../components/Sections.astro";

const build = data.find((a) => a.slug === "bleed") || data[0];
---

<Layout theme={build.theme} buildName={build.info.title}>
  <Hero build={build} />
  <Sections build={build} />
  <Footer build={build} />
</Layout>
